# ChromaDB
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=pdf_context

# HuggingFace token — only needed for gated/private models
# onnx-community/embeddinggemma-300m-ONNX is PUBLIC, no token needed
HF_TOKEN=

# Embedding model (must be an ONNX-compatible model for @xenova/transformers)
# - onnx-community/embeddinggemma-300m-ONNX   ~300MB  best quality, 100+ languages, public ✅
# - Xenova/paraphrase-multilingual-MiniLM-L12-v2  ~120MB  good, 50+ languages, public ✅
# - Xenova/bge-m3                              ~570MB  excellent retrieval, public ✅
# - Xenova/all-MiniLM-L6-v2                   ~25MB   fast, English only, public ✅
EMBEDDING_MODEL=onnx-community/embeddinggemma-300m-ONNX

# Device & precision
# EMBEDDING_DEVICE: "auto" (default) | "cpu" | "cuda" | "webgpu"
#   "auto" uses GPU if available, falls back to CPU
# EMBEDDING_DTYPE: "fp16" (default, faster+smaller) | "fp32" (most compatible) | "q8" (quantized, smallest)
#   Note: fp16 may not work on all CPUs — if you get errors, set to fp32
EMBEDDING_DEVICE=auto
EMBEDDING_DTYPE=fp16

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# UI port
UI_PORT=3131
